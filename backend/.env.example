# Backend 환경 변수 예시
# copy .env.example .env  (PowerShell: Copy-Item .env.example .env)

# --- Docker postgres (호스트에서 python main.py / apply_schema.py) ---
DATABASE_URL=postgresql://miku:miku@localhost:5432/miku

# --- Docker 컨테이너 내부 miku-backend (docker compose) ---
# DATABASE_URL=postgresql://miku:miku@postgres:5432/miku

# LLM (호스트 실행 시)
# LLM_MODEL_PATH=models/Gemma_12B
# USE_4BIT=true

# TTS (GPT-SoVITS api.py 별도 실행)
# TTS_API_URL=http://127.0.0.1:9880
